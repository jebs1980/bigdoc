# ─────────────────────────────────────────
# BIGDOC · un service RMS
# Copier en .env et remplir les valeurs
# NE JAMAIS committer le .env
# ─────────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare Turnstile (anti-spam)
TURNSTILE_SECRET=0x4AAAAAAA...
TURNSTILE_SITE_KEY=0x4AAAAAAA...

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=bonjour@bigdoc.fr
ALERT_EMAIL=ton@email.com     # email qui reçoit les alertes système

# Base de données
DATABASE_PATH=/data/bigdoc.db
